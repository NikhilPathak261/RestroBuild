fy__progress-bar--animated {\n  animation: Toastify__trackProgress linear 1 forwards;\n}\n\n.Toastify__progress-bar--controlled {\n  transition: transform 0.2s;\n}\n\n.Toastify__progress-bar--rtl {\n  right: 0;\n  left: initial;\n  transform-origin: right;\n  border-bottom-left-radius: initial;\n}\n\n.Toastify__progress-bar--wrp {\n  position: absolute;\n  overflow: hidden;\n  bottom: 0;\n  left: 0;\n  width: 100%;\n  height: 5px;\n  border-bottom-left-radius: var(--toastify-toast-bd-radius);\n  border-bottom-right-radius: var(--toastify-toast-bd-radius);\n}\n\n.Toastify__progress-bar--wrp[data-hidden='true'] {\n  opacity: 0;\n}\n\n.Toastify__progress-bar--bg {\n  opacity: var(--toastify-color-progress-bgo);\n  width: 100%;\n  height: 100%;\n}\n\n.Toastify__spinner {\n  width: 20px;\n  height: 20px;\n  box-sizing: border-box;\n  border: 2px solid;\n  border-radius: 100%;\n  border-color: var(--toastify-spinner-color-empty-area);\n  border-right-color: var(--toastify-spinner-color);\n  animation: Toastify__spin 0.65s linear infinite;\n}\n\n@keyframes Toastify__bounceInRight {\n  from,\n  60%,\n  75%,\n  90%,\n  to {\n    animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);\n  }\n  from {\n    opacity: 0;\n    transform: translate3d(3000px, 0, 0);\n  }\n  60% {\n    opacity: 1;\n    transform: translate3d(-25px, 0, 0);\n  }\n  75% {\n    transform: translate3d(10px, 0, 0);\n  }\n  90% {\n    transform: translate3d(-5px, 0, 0);\n  }\n  to {\n    transform: none;\n  }\n}\n\n@keyframes Toastify__bounceOutRight {\n  20% {\n    opacity: 1;\n    transform: translate3d(-20px, var(--y), 0);\n  }\n  to {\n    opacity: 0;\n    transform: translate3d(2000px, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__bounceInLeft {\n  from,\n  60%,\n  75%,\n  90%,\n  to {\n    animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);\n  }\n  0% {\n    opacity: 0;\n    transform: translate3d(-3000px, 0, 0);\n  }\n  60% {\n    opacity: 1;\n    transform: translate3d(25px, 0, 0);\n  }\n  75% {\n    transform: translate3d(-10px, 0, 0);\n  }\n  90% {\n    transform: translate3d(5px, 0, 0);\n  }\n  to {\n    transform: none;\n  }\n}\n\n@keyframes Toastify__bounceOutLeft {\n  20% {\n    opacity: 1;\n    transform: translate3d(20px, var(--y), 0);\n  }\n  to {\n    opacity: 0;\n    transform: translate3d(-2000px, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__bounceInUp {\n  from,\n  60%,\n  75%,\n  90%,\n  to {\n    animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);\n  }\n  from {\n    opacity: 0;\n    transform: translate3d(0, 3000px, 0);\n  }\n  60% {\n    opacity: 1;\n    transform: translate3d(0, -20px, 0);\n  }\n  75% {\n    transform: translate3d(0, 10px, 0);\n  }\n  90% {\n    transform: translate3d(0, -5px, 0);\n  }\n  to {\n    transform: translate3d(0, 0, 0);\n  }\n}\n\n@keyframes Toastify__bounceOutUp {\n  20% {\n    transform: translate3d(0, calc(var(--y) - 10px), 0);\n  }\n  40%,\n  45% {\n    opacity: 1;\n    transform: translate3d(0, calc(var(--y) + 20px), 0);\n  }\n  to {\n    opacity: 0;\n    transform: translate3d(0, -2000px, 0);\n  }\n}\n\n@keyframes Toastify__bounceInDown {\n  from,\n  60%,\n  75%,\n  90%,\n  to {\n    animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);\n  }\n  0% {\n    opacity: 0;\n    transform: translate3d(0, -3000px, 0);\n  }\n  60% {\n    opacity: 1;\n    transform: translate3d(0, 25px, 0);\n  }\n  75% {\n    transform: translate3d(0, -10px, 0);\n  }\n  90% {\n    transform: translate3d(0, 5px, 0);\n  }\n  to {\n    transform: none;\n  }\n}\n\n@keyframes Toastify__bounceOutDown {\n  20% {\n    transform: translate3d(0, calc(var(--y) - 10px), 0);\n  }\n  40%,\n  45% {\n    opacity: 1;\n    transform: translate3d(0, calc(var(--y) + 20px), 0);\n  }\n  to {\n    opacity: 0;\n    transform: translate3d(0, 2000px, 0);\n  }\n}\n\n.Toastify__bounce-enter--top-left,\n.Toastify__bounce-enter--bottom-left {\n  animation-name: Toastify__bounceInLeft;\n}\n\n.Toastify__bounce-enter--top-right,\n.Toastify__bounce-enter--bottom-right {\n  animation-name: Toastify__bounceInRight;\n}\n\n.Toastify__bounce-enter--top-center {\n  animation-name: Toastify__bounceInDown;\n}\n\n.Toastify__bounce-enter--bottom-center {\n  animation-name: Toastify__bounceInUp;\n}\n\n.Toastify__bounce-exit--top-left,\n.Toastify__bounce-exit--bottom-left {\n  animation-name: Toastify__bounceOutLeft;\n}\n\n.Toastify__bounce-exit--top-right,\n.Toastify__bounce-exit--bottom-right {\n  animation-name: Toastify__bounceOutRight;\n}\n\n.Toastify__bounce-exit--top-center {\n  animation-name: Toastify__bounceOutUp;\n}\n\n.Toastify__bounce-exit--bottom-center {\n  animation-name: Toastify__bounceOutDown;\n}\n\n@keyframes Toastify__zoomIn {\n  from {\n    opacity: 0;\n    transform: scale3d(0.3, 0.3, 0.3);\n  }\n  50% {\n    opacity: 1;\n  }\n}\n\n@keyframes Toastify__zoomOut {\n  from {\n    opacity: 1;\n  }\n  50% {\n    opacity: 0;\n    transform: translate3d(0, var(--y), 0) scale3d(0.3, 0.3, 0.3);\n  }\n  to {\n    opacity: 0;\n  }\n}\n\n.Toastify__zoom-enter {\n  animation-name: Toastify__zoomIn;\n}\n\n.Toastify__zoom-exit {\n  animation-name: Toastify__zoomOut;\n}\n\n@keyframes Toastify__flipIn {\n  from {\n    transform: perspective(400px) rotate3d(1, 0, 0, 90deg);\n    animation-timing-function: ease-in;\n    opacity: 0;\n  }\n  40% {\n    transform: perspective(400px) rotate3d(1, 0, 0, -20deg);\n    animation-timing-function: ease-in;\n  }\n  60% {\n    transform: perspective(400px) rotate3d(1, 0, 0, 10deg);\n    opacity: 1;\n  }\n  80% {\n    transform: perspective(400px) rotate3d(1, 0, 0, -5deg);\n  }\n  to {\n    transform: perspective(400px);\n  }\n}\n\n@keyframes Toastify__flipOut {\n  from {\n    transform: translate3d(0, var(--y), 0) perspective(400px);\n  }\n  30% {\n    transform: translate3d(0, var(--y), 0) perspective(400px) rotate3d(1, 0, 0, -20deg);\n    opacity: 1;\n  }\n  to {\n    transform: translate3d(0, var(--y), 0) perspective(400px) rotate3d(1, 0, 0, 90deg);\n    opacity: 0;\n  }\n}\n\n.Toastify__flip-enter {\n  animation-name: Toastify__flipIn;\n}\n\n.Toastify__flip-exit {\n  animation-name: Toastify__flipOut;\n}\n\n@keyframes Toastify__slideInRight {\n  from {\n    transform: translate3d(110%, 0, 0);\n    visibility: visible;\n  }\n  to {\n    transform: translate3d(0, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__slideInLeft {\n  from {\n    transform: translate3d(-110%, 0, 0);\n    visibility: visible;\n  }\n  to {\n    transform: translate3d(0, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__slideInUp {\n  from {\n    transform: translate3d(0, 110%, 0);\n    visibility: visible;\n  }\n  to {\n    transform: translate3d(0, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__slideInDown {\n  from {\n    transform: translate3d(0, -110%, 0);\n    visibility: visible;\n  }\n  to {\n    transform: translate3d(0, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__slideOutRight {\n  from {\n    transform: translate3d(0, var(--y), 0);\n  }\n  to {\n    visibility: hidden;\n    transform: translate3d(110%, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__slideOutLeft {\n  from {\n    transform: translate3d(0, var(--y), 0);\n  }\n  to {\n    visibility: hidden;\n    transform: translate3d(-110%, var(--y), 0);\n  }\n}\n\n@keyframes Toastify__slideOutDown {\n  from {\n    transform: translate3d(0, var(--y), 0);\n  }\n  to {\n    visibility: hidden;\n    transform: translate3d(0, 500px, 0);\n  }\n}\n\n@keyframes Toastify__slideOutUp {\n  from {\n    transform: translate3d(0, var(--y), 0);\n  }\n  to {\n    visibility: hidden;\n    transform: translate3d(0, -500px, 0);\n  }\n}\n\n.Toastify__slide-enter--top-left,\n.Toastify__slide-enter--bottom-left {\n  animation-name: Toastify__slideInLeft;\n}\n\n.Toastify__slide-enter--top-right,\n.Toastify__slide-enter--bottom-right {\n  animation-name: Toastify__slideInRight;\n}\n\n.Toastify__slide-enter--top-center {\n  animation-name: Toastify__slideInDown;\n}\n\n.Toastify__slide-enter--bottom-center {\n  animation-name: Toastify__slideInUp;\n}\n\n.Toastify__slide-exit--top-left,\n.Toastify__slide-exit--bottom-left {\n  animation-name: Toastify__slideOutLeft;\n  animation-timing-function: ease-in;\n  animation-duration: 0.3s;\n}\n\n.Toastify__slide-exit--top-right,\n.Toastify__slide-exit--bottom-right {\n  animation-name: Toastify__slideOutRight;\n  animation-timing-function: ease-in;\n  animation-duration: 0.3s;\n}\n\n.Toastify__slide-exit--top-center {\n  animation-name: Toastify__slideOutUp;\n  animation-timing-function: ease-in;\n  animation-duration: 0.3s;\n}\n\n.Toastify__slide-exit--bottom-center {\n  animation-name: Toastify__slideOutDown;\n  animation-timing-function: ease-in;\n  animation-duration: 0.3s;\n}\n\n@keyframes Toastify__spin {\n  from {\n    transform: rotate(0deg);\n  }\n  to {\n    transform: rotate(360deg);\n  }\n}\n"],["STYLE",{},":root {\n  color: #1f2933;\n  background: #f7f8fa;\n  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n  line-height: 1.5;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  min-width: 320px;\n}\n\n.skip-link {\n  background: #111827;\n  border-radius: 0 0 6px 0;\n  color: #fff;\n  font-weight: 800;\n  left: 0;\n  padding: 0.75rem 1rem;\n  position: fixed;\n  top: 0;\n  transform: translateY(-120%);\n  transition: transform 0.15s ease;\n  z-index: 1000;\n}\n\n.skip-link:focus {\n  transform: translateY(0);\n}\n\na {\n  color: #b42318;\n  text-decoration: none;\n}\n\nbutton,\ninput {\n  font: inherit;\n}\n\nbutton {\n  border: 0;\n  border-radius: 6px;\n  background: #b42318;\n  color: #fff;\n  cursor: pointer;\n  font-weight: 700;\n  padding: 0.8rem 1rem;\n}\n\nbutton:disabled {\n  cursor: not-allowed;\n  opacity: 0.7;\n}\n\n.brand {\n  color: #111827;\n  font-size: 1.3rem;\n  font-weight: 800;\n}\n\n.eyebrow {\n  color: #b42318;\n  font-size: 0.78rem;\n  font-weight: 800;\n  letter-spacing: 0.08em;\n  margin: 0 0 0.35rem;\n  text-transform: uppercase;\n}\n\n.muted {\n  color: #667085;\n}\n\n.status-badge {\n  background: #f2f4f7;\n  border-radius: 999px;\n  color: #475467;\n  display: inline-block;\n  font-size: 0.78rem;\n  font-weight: 800;\n  margin-bottom: 0.35rem;\n  padding: 0.2rem 0.55rem;\n}\n\n.status-badge.success {\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.auth-shell {\n  display: grid;\n  grid-template-columns: minmax(320px, 480px) 1fr;\n  min-height: 100vh;\n}\n\n.auth-panel {\n  align-content: center;\n  background: #fff;\n  display: grid;\n  gap: 2rem;\n  padding: 2rem;\n}\n\n.auth-aside {\n  align-items: center;\n  background: linear-gradient(rgba(17, 24, 39, 0.55), rgba(17, 24, 39, 0.55)), url(\"https://images.unsplash.com/photo-1552566626-52f8b828add9?auto=format&fit=crop&w=1400&q=80\");\n  background-position: center;\n  background-size: cover;\n  color: #fff;\n  display: flex;\n  padding: 4rem;\n}\n\n.auth-aside div {\n  max-width: 620px;\n}\n\n.auth-aside h1 {\n  font-size: clamp(2rem, 4vw, 4rem);\n  line-height: 1.05;\n  margin: 0 0 1rem;\n}\n\n.form-card {\n  display: grid;\n  gap: 1rem;\n  max-width: 380px;\n  width: 100%;\n}\n\n.form-card h1 {\n  margin: 0;\n}\n\n.form-card label {\n  color: #344054;\n  display: grid;\n  font-weight: 700;\n  gap: 0.35rem;\n}\n\n.form-card input {\n  border: 1px solid #d0d5dd;\n  border-radius: 6px;\n  padding: 0.75rem;\n}\n\n.demo-login-panel {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 0.75rem;\n  padding: 1rem;\n}\n\n.demo-login-panel span {\n  color: #667085;\n  font-size: 0.85rem;\n  font-weight: 800;\n  text-transform: uppercase;\n}\n\n.demo-login-panel div {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5rem;\n}\n\n.dashboard-form {\n  background: #fff;\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 1rem;\n  max-width: 820px;\n  padding: 1.25rem;\n}\n\n.dashboard-form label {\n  color: #344054;\n  display: grid;\n  font-weight: 700;\n  gap: 0.35rem;\n}\n\n.dashboard-form input,\n.dashboard-form textarea,\n.dashboard-form select {\n  border: 1px solid #d0d5dd;\n  border-radius: 6px;\n  font: inherit;\n  padding: 0.75rem;\n  resize: vertical;\n}\n\n.form-hint {\n  color: var(--muted);\n  font-size: 0.85rem;\n}\n\n.form-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n}\n\n.settings-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);\n}\n\n.management-grid {\n  align-items: start;\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: minmax(280px, 420px) minmax(0, 1fr);\n}\n\n.management-grid.wide {\n  grid-template-columns: minmax(300px, 520px) minmax(0, 1fr);\n}\n\n.website-preview,\n.publish-panel,\n.list-panel {\n  background: #fff;\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  padding: 1.25rem;\n}\n\n.website-preview {\n  background: var(--secondary);\n  border-color: color-mix(in srgb, var(--primary), #fff 75%);\n  color: #1f2933;\n  display: grid;\n  place-content: center;\n}\n\n.website-preview span {\n  color: var(--primary);\n  font-weight: 800;\n}\n\n.website-preview h2 {\n  color: var(--primary);\n  font-size: 2rem;\n  line-height: 1.1;\n}\n\n.publish-panel {\n  align-items: center;\n  display: flex;\n  gap: 1rem;\n  justify-content: space-between;\n}\n\n.button-row,\n.table-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5rem;\n}\n\n.checkbox-label {\n  align-items: center;\n  display: flex !important;\n  flex-direction: row;\n}\n\n.checkbox-label input {\n  width: auto;\n}\n\n.ghost-button.inline {\n  margin-top: 0;\n}\n\n.danger-button {\n  background: #d92d20;\n}\n\n.list-header {\n  align-items: center;\n  display: flex;\n  gap: 1rem;\n  justify-content: space-between;\n  margin-bottom: 1rem;\n}\n\n.list-header h2 {\n  margin: 0;\n}\n\n.list-header input,\n.list-header select {\n  border: 1px solid #d0d5dd;\n  border-radius: 6px;\n  font: inherit;\n  min-width: 220px;\n  padding: 0.65rem 0.75rem;\n}\n\n.responsive-table {\n  overflow-x: auto;\n}\n\n.pagination-controls {\n  align-items: center;\n  border-top: 1px solid #eaecf0;\n  display: flex;\n  gap: 1rem;\n  justify-content: space-between;\n  margin-top: 1rem;\n  padding-top: 1rem;\n}\n\n.pagination-controls span {\n  color: #667085;\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.pagination-controls div {\n  align-items: center;\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.75rem;\n}\n\ntable {\n  border-collapse: collapse;\n  width: 100%;\n}\n\nth,\ntd {\n  border-bottom: 1px solid #eaecf0;\n  padding: 0.85rem;\n  text-align: left;\n  vertical-align: middle;\n}\n\nth {\n  color: #667085;\n  font-size: 0.85rem;\n}\n\n.empty-state.compact {\n  padding: 1rem;\n}\n\n.dashboard-shell {\n  display: grid;\n  grid-template-columns: 260px 1fr;\n  min-height: 100vh;\n}\n\n.sidebar {\n  background: #fff;\n  border-right: 1px solid #eaecf0;\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n  padding: 1.5rem;\n}\n\n.sidebar nav {\n  display: grid;\n  gap: 0.25rem;\n}\n\n.sidebar nav a {\n  border-radius: 6px;\n  color: #344054;\n  font-weight: 700;\n  padding: 0.7rem 0.8rem;\n}\n\n.sidebar nav a.active,\n.sidebar nav a:hover {\n  background: #fff1f0;\n  color: #b42318;\n}\n\n.ghost-button {\n  background: #f2f4f7;\n  color: #344054;\n  margin-top: auto;\n}\n\n.dashboard-main {\n  padding: 2rem;\n}\n\n.page-stack {\n  display: grid;\n  gap: 1.5rem;\n}\n\n.page-stack h1 {\n  margin: 0;\n}\n\n.metric-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n}\n\n.metric-card,\n.empty-state {\n  background: #fff;\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  padding: 1.25rem;\n}\n\n.metric-card {\n  display: grid;\n  gap: 0.5rem;\n}\n\n.metric-card span {\n  color: #667085;\n}\n\n.metric-card strong {\n  font-size: 1.8rem;\n}\n\n.public-shell {\n  min-height: 100vh;\n}\n\n.public-header {\n  align-items: center;\n  background: #fff;\n  border-bottom: 1px solid #eaecf0;\n  display: flex;\n  justify-content: space-between;\n  padding: 1rem 1.5rem;\n}\n\n.public-header nav {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 1rem;\n}\n\n.public-home,\n.center-page,\n.public-content {\n  display: grid;\n  margin: 0 auto;\n  max-width: 900px;\n  min-height: calc(100vh - 74px);\n  padding: 4rem 1.5rem;\n  place-content: center;\n}\n\n.public-home h1,\n.center-page h1,\n.public-content h1 {\n  color: var(--primary, #111827);\n  font-size: clamp(2rem, 5vw, 4rem);\n  line-height: 1.05;\n  margin: 0;\n}\n\n.public-home {\n  gap: 1.5rem;\n  width: 100%;\n}\n\n.public-home-content {\n  display: grid;\n  gap: 1rem;\n  width: 100%;\n}\n\n.public-brand-row {\n  align-items: center;\n  display: flex;\n  flex-wrap: wrap;\n  gap: 1rem;\n}\n\n.public-logo {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  height: 88px;\n  object-fit: cover;\n  width: 88px;\n}\n\n.public-cover {\n  aspect-ratio: 16 / 7;\n  border-radius: 8px;\n  max-height: 320px;\n  object-fit: cover;\n  width: 100%;\n}\n\n.public-cover.compact {\n  aspect-ratio: 16 / 8;\n  max-width: 760px;\n}\n\n.public-content {\n  gap: 1rem;\n  place-content: start center;\n  width: 100%;\n}\n\n.public-content > p:not(.eyebrow) {\n  font-size: 1.1rem;\n  max-width: 760px;\n}\n\n.state-page {\n  gap: 1rem;\n  text-align: center;\n}\n\n.loading-spinner {\n  animation: spin 0.8s linear infinite;\n  border: 4px solid #eaecf0;\n  border-radius: 999px;\n  border-top-color: #b42318;\n  height: 44px;\n  justify-self: center;\n  width: 44px;\n}\n\n.contact-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  width: min(760px, 100%);\n}\n\n.contact-grid article {\n  background: #fff;\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 0.35rem;\n  padding: 1.25rem;\n}\n\n.contact-grid span {\n  color: #667085;\n  font-size: 0.85rem;\n  font-weight: 800;\n  text-transform: uppercase;\n}\n\n.contact-grid strong {\n  overflow-wrap: anywhere;\n}\n\n.public-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.75rem;\n  margin-top: 1rem;\n}\n\n.public-actions a {\n  background: var(--primary, #b42318);\n  border-radius: 6px;\n  color: #fff;\n  font-weight: 800;\n  padding: 0.75rem 1rem;\n}\n\n.public-menu {\n  display: grid;\n  gap: 1.5rem;\n  margin: 0 auto;\n  max-width: 1100px;\n  padding: 2rem 1.5rem;\n}\n\n.public-menu h1 {\n  margin: 0;\n}\n\n.public-menu-filters {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: minmax(0, 1fr) repeat(5, minmax(130px, 180px));\n}\n\n.public-menu-filters input,\n.public-menu-filters select {\n  border: 1px solid #d0d5dd;\n  border-radius: 6px;\n  font: inherit;\n  padding: 0.75rem;\n}\n\n.menu-card-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n}\n\n.menu-card {\n  background: #fff;\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.menu-card img {\n  aspect-ratio: 4 / 3;\n  display: block;\n  object-fit: cover;\n  width: 100%;\n}\n\n.menu-card div {\n  display: grid;\n  gap: 0.35rem;\n  padding: 1rem;\n}\n\n.menu-card span {\n  color: #b42318;\n  font-size: 0.85rem;\n  font-weight: 800;\n}\n\n.menu-card h2,\n.menu-card p {\n  margin: 0;\n}\n\n.review-form-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n}\n\n.review-mini-form {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 0.75rem;\n  padding: 1rem;\n}\n\n.review-mini-form h3 {\n  margin: 0;\n}\n\n.success-text {\n  color: #027a48;\n  font-weight: 700;\n  margin: 0;\n}\n\n.review-mini-form label {\n  display: grid;\n  gap: 0.35rem;\n}\n\n.review-mini-form select,\n.review-mini-form textarea {\n  border: 1px solid #d0d5dd;\n  border-radius: 6px;\n  font: inherit;\n  padding: 0.65rem;\n}\n\n.dish-detail-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: minmax(240px, 360px) minmax(0, 1fr);\n}\n\n.dish-detail-grid img {\n  border-radius: 8px;\n  height: 100%;\n  max-height: 360px;\n  object-fit: cover;\n  width: 100%;\n}\n\n.analytics-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n}\n\n.analytics-list {\n  display: grid;\n  gap: 0.75rem;\n}\n\n.analytics-list div {\n  align-items: center;\n  border-bottom: 1px solid #eaecf0;\n  display: flex;\n  justify-content: space-between;\n  padding-bottom: 0.75rem;\n}\n\n.rating-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(5, minmax(0, 1fr));\n}\n\n.active-order-grid {\n  display: grid;\n  gap: 0.75rem;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n}\n\n.active-order-card {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 0.75rem;\n  padding: 1rem;\n}\n\n.active-order-card h3,\n.active-order-card p {\n  margin: 0;\n}\n\n.order-status-pill {\n  background: #fff1f0;\n  border-radius: 999px;\n  color: #b42318;\n  display: inline-block;\n  font-size: 0.78rem;\n  font-weight: 800;\n  margin-bottom: 0.35rem;\n  padding: 0.2rem 0.55rem;\n  text-transform: capitalize;\n}\n\n.order-tracker-summary {\n  align-items: center;\n  display: flex;\n  gap: 1rem;\n  justify-content: space-between;\n}\n\n.order-tracker-summary h2,\n.order-tracker-summary span {\n  margin: 0;\n}\n\n.order-tracker-summary > div:last-child {\n  text-align: right;\n}\n\n.order-tracker-summary > div:last-child span {\n  color: #667085;\n  display: block;\n  font-size: 0.85rem;\n  font-weight: 800;\n  text-transform: uppercase;\n}\n\n.order-tracker-summary > div:last-child strong {\n  color: #111827;\n  font-size: 1.4rem;\n}\n\n.order-timeline {\n  counter-reset: order-step;\n  display: grid;\n  gap: 0.75rem;\n  list-style: none;\n  margin: 1rem 0 0;\n  padding: 0;\n}\n\n.order-timeline li {\n  border-left: 4px solid #eaecf0;\n  display: grid;\n  gap: 0.2rem;\n  padding: 0.25rem 0 0.25rem 1rem;\n}\n\n.order-timeline li.completed {\n  border-left-color: #12b76a;\n}\n\n.order-timeline li.current {\n  border-left-color: #b42318;\n}\n\n.order-timeline li.upcoming {\n  color: #667085;\n}\n\n.order-timeline span {\n  font-weight: 800;\n}\n\n.order-timeline strong {\n  font-weight: 500;\n}\n\n.order-timeline time {\n  color: #667085;\n  font-size: 0.85rem;\n}\n\n.bill-summary-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n}\n\n.bill-summary-grid article {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 0.35rem;\n  padding: 1rem;\n}\n\n.bill-summary-grid span {\n  color: #667085;\n  font-size: 0.8rem;\n  font-weight: 800;\n  text-transform: uppercase;\n}\n\n.bill-summary-grid strong {\n  color: #111827;\n  font-size: 1.5rem;\n  text-transform: capitalize;\n}\n\n.bill-summary-grid p {\n  margin: 0;\n}\n\n.qr-preview {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  height: 88px;\n  object-fit: contain;\n  padding: 0.35rem;\n  width: 88px;\n}\n\n.compact-list {\n  gap: 0.35rem;\n}\n\n.compact-list div,\n.compact-list a {\n  border-bottom: 0;\n  padding-bottom: 0;\n}\n\n.image-preview-grid {\n  display: grid;\n  gap: 1rem;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n}\n\n.image-preview-grid article {\n  border: 1px solid #eaecf0;\n  border-radius: 8px;\n  display: grid;\n  gap: 0.5rem;\n  padding: 0.75rem;\n}\n\n.image-preview-grid span {\n  color: #667085;\n  font-size: 0.85rem;\n  font-weight: 800;\n}\n\n.image-preview-grid img {\n  aspect-ratio: 16 / 9;\n  border-radius: 6px;\n  object-fit: cover;\n  width: 100%;\n}\n\n.table-media-cell {\n  align-items: center;\n  display: flex;\n  gap: 0.75rem;\n}\n\n.table-media-cell img {\n  border-radius: 6px;\n  height: 44px;\n  object-fit: cover;\n  width: 44px;\n}\n\n@media (max-width: 900px) {\n  .auth-shell,\n  .dashboard-shell {\n    grid-template-columns: 1fr;\n  }\n\n  .auth-aside {\n    display: none;\n  }\n\n  .sidebar {\n    border-bottom: 1px solid #eaecf0;\n    border-right: 0;\n  }\n\n  .metric-grid,\n  .settings-grid,\n  .management-grid,\n  .management-grid.wide,\n  .analytics-grid,\n  .menu-card-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 560px) {\n  .metric-grid,\n  .form-grid,\n  .settings-grid,\n  .management-grid,\n  .management-grid.wide,\n  .public-menu-filters,\n  .dish-detail-grid,\n  .menu-card-grid,\n  .active-order-grid,\n  .bill-summary-grid,\n  .review-form-grid,\n  .analytics-grid,\n  .rating-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .image-preview-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .publish-panel {\n    align-items: stretch;\n    flex-direction: column;\n  }\n\n  .dashboard-main {\n    padding: 1rem;\n  }\n\n  .public-header {\n    align-items: flex-start;\n    flex-direction: column;\n    gap: 0.75rem;\n  }\n\n  .list-header {\n    align-items: stretch;\n    flex-direction: column;\n  }\n\n  .list-header input,\n  .list-header select {\n    min-width: 0;\n    width: 100%;\n  }\n\n  .pagination-controls {\n    align-items: stretch;\n    flex-direction: column;\n  }\n\n  .contact-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@keyframes spin {\n  to {\n    transform: rotate(360deg);\n  }\n}\n"],["STYLE",{},":root {\n  --toastify-color-light: #fff;\n  --toastify-color-dark: #121212;\n  --toastify-color-info: #3498db;\n  --toastify-color-success: #07bc0c;\n  --toastify-color-warning: #f1c40f;\n  --toastify-color-error: hsl(6, 78%, 57%);\n  --toastify-color-transparent: rgba(255, 255, 255, 0.7);\n\n  --toastify-icon-color-info: var(--toastify-color-info);\n  --toastify-icon-color-success: var(--toastify-color-success);\n  --toastify-icon-color-warning: var(--toastify-color-warning);\n  --toastify-icon-color-error: var(--toastify-color-error);\n\n  --toastify-container-width: fit-content;\n  --toastify-toast-width: 320px;\n  --toastify-toast-offset: 16px;\n  --toastify-toast-top: max(var(--toastify-toast-offset), env(safe-area-inset-top));\n  --toastify-toast-right: max(var(--toastify-toast-offset), env(safe-area-inset-right));\n  --toastify-toast-left: max(var(--toastify-toast-offset), env(safe-area-inset-left));\n  --toastify-toast-bottom: max(var(--toastify-toast-offset), env(safe-area-inset-bottom));\n  --toastify-toast-background: #fff;\n  --toastify-toast-padding: 14px;\n  --toastify-toast-min-height: 64px;\n  --toastify-toast-max-height: 800px;\n  --toastify-toast-bd-radius: 6px;\n  --toastify-toast-shadow: 0px 4px 12px rgba(0, 0, 0, 0.1);\n  --toastify-font-family: sans-serif;\n  --toastify-z-index: 9999;\n  --toastify-text-color-light: #757575;\n  --toastify-text-color-dark: #fff;\n\n  /* Used only for colored theme */\n  --toastify-text-color-info: #fff;\n  --toastify-text-color-success: #fff;\n  --toastify-text-color-warning: #fff;\n  --toastify-text-color-error: #fff;\n\n  --toastify-spinner-color: #616161;\n  --toastify-spinner-color-empty-area: #e0e0e0;\n  --toastify-color-progress-light: linear-gradient(to right, #4cd964, #5ac8fa, #007aff, #34aadc, #5856d6, #ff2d55);\n  --toastify-color-progress-dark: #bb86fc;\n  --toastify-color-progress-info: var(--toastify-color-info);\n  --toastify-color-progress-success: var(--toastify-color-success);\n  --toastify-color-progress-warning: var(--toastify-color-warning);\n  --toastify-color-progress-error: var(--toastify-color-error);\n  /* used to control the opacity of the progress trail */\n  --toastify-color-progress-bgo: 0.2;\n}\n\n.Toastify__toast-container {\n  z-index: var(--toastify-z-index);\n  -webkit-transform: translate3d(0, 0, var(--toastify-z-index));\n  position: fixed;\n  width: var(--toastify-container-width);\n  box-sizing: border-box;\n  color: #fff;\n  display: flex;\n  flex-direction: column;\n}\n\n.Toastify__toast-container--top-left {\n  top: var(--toastify-toast-top);\n  left: var(--toastify-toast-left);\n}\n.Toastify__toast-container--top-center {\n  top: var(--toastify-toast-top);\n  left: 50%;\n  transform: translateX(-50%);\n  align-items: center;\n}\n.Toastify_