#!/usr/bin/env sh
set -eu

MAVEN_VERSION=3.9.9
MAVEN_DIR="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MAVEN_CMD="${MAVEN_DIR}/bin/mvn"
MAVEN_URL="https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.zip"
MAVEN_ZIP="${TMPDIR:-/tmp}/apache-maven-${MAVEN_VERSION}-bin.zip"

if [ ! -x "$MAVEN_CMD" ]; then
  echo "Downloading Apache Maven ${MAVEN_VERSION}..."
  mkdir -p "${HOME}/.m2/wrapper/dists"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$MAVEN_URL" -o "$MAVEN_ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$MAVEN_URL" -O "$MAVEN_ZIP"
  else
    echo "curl or wget is required to download Maven." >&2
    exit 1
  fi
  unzip -q -o "$MAVEN_ZIP" -d "${HOME}/.m2/wrapper/dists"
  rm -f "$MAVEN_ZIP"
fi

exec "$MAVEN_CMD" "$@"
